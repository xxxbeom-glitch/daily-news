# .env 파일을 만들고 아래 값을 입력하세요.
# 주의: 따옴표(") 사용 시 값에 포함되어 API 오류 발생! = 뒤에 키만 붙여넣으세요.

# AI API 키 (설정 > 연결상태 체크 시 사용)
# Google Gemini: https://aistudio.google.com/apikey (39자)
VITE_GEMINI_API_KEY=

# OpenAI ChatGPT: https://platform.openai.com/api-keys (sk-proj-로 시작)
VITE_OPENAI_API_KEY=

# 구글 드라이브 내보내기 (설정 > 저장된 아카이브 > 내보내기)
# Google Cloud Console에서 OAuth 2.0 클라이언트 ID (웹 애플리케이션) 생성
# https://console.cloud.google.com/apis/credentials
# 사용자 인증 정보 > OAuth 2.0 클라이언트 ID > 웹 애플리케이션
# 허용된 JavaScript 원본에 개발/배포 URL 추가 (예: http://localhost:5173)
VITE_GOOGLE_CLIENT_ID=
